<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<VBox xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="multimine.app.multimineapp.MultiSumController" spacing="20.0">
   <children>
      <Text fx:id="titleText" text="Player 1 Wins!" style="-fx-font-size: 40px; -fx-font-family: 'Courier New Bold';"/>
      <Text fx:id="resultsText" text="Player 1: 15.2s | Player 2: 8.1s" style="-fx-font-size: 24px; -fx-font-family: 'Courier New';"/>
      <HBox spacing="20.0">
         <Button fx:id="retryBtn" text="Rematch" onAction="#handleRematch" style="-fx-font-size: 20px;"/>
         <Button fx:id="menuBtn" text="Main Menu" onAction="#handleMenu" style="-fx-font-size: 20px;"/>
      </HBox>
   </children>
</VBox>
