<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<BorderPane prefHeight="500.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="multimine.app.multimineapp.MultiSumController">
   <center>
        <AnchorPane BorderPane.alignment="CENTER">
            <children>
                <Text fx:id="titleText" layoutX="131.0" layoutY="175.0" style="-fx-font-size: 48px; -fx-font-family: 'Courier New Bold'; -fx-fill: linear-gradient(to right, #ff6b6b, #4ecdc4);" text="Player 1 Wins!" AnchorPane.leftAnchor="131.0" AnchorPane.topAnchor="123.203125" />
            </children>
        </AnchorPane>
    </center>
   <bottom>
      <AnchorPane prefHeight="124.0" prefWidth="658.0" BorderPane.alignment="CENTER">
         <children>
            <Button fx:id="retryBtn" layoutX="83.0" layoutY="44.0" onAction="#handleRematch" prefHeight="67.0" prefWidth="168.0" text="Rematch">
               <font>
                  <Font name="Courier New" size="21.0" />
               </font></Button>
            <Button fx:id="menuBtn" layoutX="305.0" layoutY="43.0" onAction="#handleMenu" prefHeight="69.0" prefWidth="180.0" text="Main Menu">
               <font>
                  <Font name="Courier New" size="17.0" />
               </font></Button>
         </children>
         <padding>
            <Insets bottom="30.0" left="20.0" right="20.0" top="20.0" />
         </padding>
      </AnchorPane>
   </bottom>
   <top>
      <Text smooth="false" style="-fx-font-size: 16px; -fx-font-family: 'Courier New'; -fx-fill: #95a5a6;" text="Game Over - Final Results" BorderPane.alignment="CENTER">
         <font>
            <Font size="21.0" />
         </font></Text>
   </top>
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
</BorderPane>
